{
  "name": "immich-cast",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "api": "nodemon --watch src/api --exec tsx src/api/server.ts",
    "dev": "cd src/web && vite --host",
    "start": "concurrently \"npm run api\" \"npm run dev\"",
    "build": "cd src/web && vite build --outDir ../../dist",
    "preview": "cd src/web && vite preview",
    "check": "cd src/web && svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tsconfig/svelte": "^5.0.4",
    "@types/castv2": "^0.1.3",
    "@types/node": "^22.14.1",
    "concurrently": "^9.1.2",
    "nodemon": "^3.1.9",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-svelte": "^3.3.3",
    "svelte": "^5.27.0",
    "svelte-check": "^4.1.6",
    "tailwindcss": "^4.1.5",
    "typescript": "~5.8.3",
    "vite": "^6.2.6"
  },
  "dependencies": {
    "@fastify/static": "^8.1.1",
    "@tailwindcss/postcss": "^4.1.5",
    "axios": "^1.8.4",
    "castv2": "^0.1.10",
    "dayjs": "^1.11.13",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.0",
    "redaxios": "^0.5.1",
    "tsx": "^4.19.3"
  }
}
