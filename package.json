{
  "name": "immich-cast",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "api": "nodemon --watch src/api --exec tsx src/api/server.ts",
    "dev": "cd src/web && vite --host",
    "start": "concurrently \"npm run api\" \"npm run dev\"",
    "build": "cd src/web && vite build --outDir ../../dist",
    "preview": "cd src/web && vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tsconfig/svelte": "^5.0.8",
    "@types/castv2": "^0.1.3",
    "@types/node": "^25.3.3",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.0",
    "svelte": "^5.53.6",
    "svelte-check": "^4.4.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@fastify/static": "^9.0.0",
    "@tailwindcss/postcss": "^4.2.1",
    "axios": "^1.13.6",
    "castv2": "^0.1.10",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "redaxios": "^0.5.1",
    "tsx": "^4.21.0"
  }
}
